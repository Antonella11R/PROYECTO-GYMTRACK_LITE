{
    "name": "gymtrack-lite/app",
    "description": "GymTrack Lite reestructurado con DDD y arquitectura limpia.",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "test/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist"
    },
    "config": {
        "sort-packages": true
    }
}
